{
  "_meta": {
    "description": "Age-matched normative baselines for S.E.E.D. behavioral metrics",
    "age_groups": ["24-30m", "30-36m", "36-42m", "42-48m", "48-54m", "54-60m"],
    "signals": ["gaze", "reaction_latency", "touch_precision", "imitation", "engagement"],
    "sources": {
      "gaze": "Swanson MR et al. 2013 (Western cohort, APPROXIMATE for Indian population); IAP developmental surveillance 2015",
      "reaction_latency": "Chawarska K et al. 2013 (Western cohort, APPROXIMATE); Jones W & Klin A 2013 Nature",
      "touch_precision": "IAP motor milestones 2015; Juneja M et al. 2012 Indian Pediatrics (APPROXIMATE for digital touch tasks)",
      "imitation": "Charman T et al. 1997 (controls); Rogers SJ et al. 2008 — NOTE: experimental paradigm, correlation under testing",
      "engagement": "SEED pilot estimate (APPROXIMATE — replace with India-collected data pre-deployment)",
      "WARNING": "All values marked APPROXIMATE must be replaced with India-collected clinical data before any clinical deployment"
    },
    "schema": {
      "joint_attention_ratio": "proportion 0-1 of frames with gaze within ±15° of screen center",
      "gaze_variability": "std dev of gaze_vector_x in radians",
      "sustained_gaze_events_per_min": "count of gaze sequences >1.5s per minute",
      "social_latency_mean_ms": "mean ms from social stimulus onset to first touch response",
      "social_vs_nonsocial_ratio": "latency ratio social/nonsocial (>1.0 = slower to social)",
      "latency_cv": "coefficient of variation of reaction latencies (std/mean)",
      "accuracy_score": "proportion 0-1 of taps within target_radius",
      "drag_smoothness": "mean deviation px from ideal drag path (lower = smoother)",
      "motor_consistency": "std dev of per-trial accuracy (lower = more consistent)",
      "imitation_accuracy": "proportion 0-1 of gestures correctly reproduced within 3s window",
      "imitation_latency_ms": "mean ms from avatar action to child response",
      "imitation_sequence_score": "weighted score 0-1 for multi-step sequence completion",
      "session_completion_rate": "proportion 0-1 of game modules completed",
      "disengagement_events": "count of >3s off-screen gaze periods per session",
      "attention_recovery_ms": "mean ms to re-engage after disengagement event"
    }
  },
